# Copy to .env and fill in real values. Never commit .env.

# ── MT5 account (optional — usually picked up from running terminal) ──
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── ZeroMQ overrides (optional) ──────────────────────
# ZMQ_HOST=localhost
# ZMQ_SIGNAL_PORT=5555
# ZMQ_DATA_PORT=5556

# ── Notifications ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Economic calendar provider ───────────────────────
# Options: forexfactory | finnhub
NEWS_PROVIDER=forexfactory
FINNHUB_API_KEY=

# ── Runtime ──────────────────────────────────────────
LOG_LEVEL=INFO
ENV=dev
